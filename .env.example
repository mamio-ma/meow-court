# ============================================================
# Feline Court · 环境变量模板
# 复制到 .env.local 并填入实际值；.env.local 已被 gitignore
# 部署到 Vercel 时把这些配到 Environment Variables
# ============================================================

# --- Anthropic API (必填) ---
# 从 https://console.anthropic.com/settings/keys 拿 sk-ant-... 开头的 key
ANTHROPIC_API_KEY=sk-ant-...

# 可选：默认 Sonnet 4.5；想换 Sonnet 4.6 / Haiku 只改这里
# 完整列表见 https://docs.anthropic.com/en/docs/about-claude/models
ANTHROPIC_MODEL_ID=claude-sonnet-4-5-20250929

# --- Redis (仅远程双人模式需要) ---
# Vercel Marketplace Integration 一键 provision 会自动注入 KV_REST_API_URL 和
# KV_REST_API_TOKEN；代码同时兼容 UPSTASH_REDIS_REST_* 老命名，两组任一即可。
# 本地开发单机模式不用配也能跑，只是远程模式会 503。
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx
# 或 Vercel Marketplace 自动注入的这两个:
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=xxx
