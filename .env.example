# ============================================================
# Feline Court · 环境变量模板
# 复制到 .env.local 并填入实际值；.env.local 已被 gitignore
# 部署到 Vercel 时把这些配到 Environment Variables
# ============================================================

# --- AWS Bedrock (必填) ---
# Bearer token from Bedrock API Keys console
AWS_BEARER_TOKEN_BEDROCK=ABSK...

# Region + inference profile ID（不是 model ID——Sonnet 4.6 需要 profile 才能 on-demand 调用）
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# --- Redis (仅远程双人模式需要) ---
# Vercel Marketplace Integration 一键 provision 会自动注入 KV_REST_API_URL 和
# KV_REST_API_TOKEN；代码同时兼容 UPSTASH_REDIS_REST_* 老命名，两组任一即可。
# 本地开发单机模式不用配也能跑，只是远程模式会 503。
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx
# 或 Vercel Marketplace 自动注入的这两个:
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=xxx
